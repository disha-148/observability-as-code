{
  "name": "@instana/stanctl-fleet",
  "version": "1.0.0",
  "description": "Fleet support for stanctl",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "stanctl-fleet": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "pkg": "pkg . --output dist/stanctl-fleet"
  },
  "pkg": {
    "assets": [
      "dist/**/*.js",
      "node_modules/**/*"
    ],
    "targets": [
      "node18-macos",
      "node18-linux",
      "node18-win"
    ]
  },
  "dependencies": {
    "axios": "^1.7.2",
    "winston": "^3.13.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@types/winston": "^2.4.4",
    "@types/yargs": "^17.0.32",
    "jest": "^30.4.2",
    "pkg": "^5.8.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
